.global main
.extern printf
.extern rand
.extern get_bound

.section .data
fmt_num:   .asciz "%d "
fmt_run:   .asciz "Run length: %d\n"
fmt_total: .asciz "Total number of runs: %d\n"
newline:   .asciz "\n"

.section .bss
.lcomm arr, 800   @ 200 int 
.section .text





@ main
main:
   push {lr}

   ldr r0, =arr
   bl roll_dice

   ldr r4, =arr
   mov r5, #0

print_loop:
   cmp r5, #200
   bge print_done
   ldr r1, [r4, r5, LSL #2]
   ldr r0, =fmt_num
   bl printf
   add r5, r5, #1
   b print_loop

print_done:
   ldr r0, =newline
   bl printf

   ldr r0, =arr
   bl count_run

   mov r0, #0
   pop {lr}
   bx lr
